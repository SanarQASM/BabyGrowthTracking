<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme for Android 12+ (API 31+) -->
    <!-- Makes system splash INVISIBLE for seamless transition to Compose splash -->
    <style name="Theme.BabyGrowth" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Match your Compose splash background -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- DISABLE Android 12+ splash screen completely -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>

        <!-- Prevent window preview flash -->
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>